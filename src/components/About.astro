---
import { Image } from "astro:assets";
import Container from "./common/Container.astro";
import Divider from "./common/Divider.astro";

const highlightedStyle = `text-white underline decoration-dashed decoration-pink-600`;
const getDiffOfYears = () => {
  const start = new Date(2017, 10, 1).getTime();
  const now = new Date().getTime();
  const diffInMs = Math.abs(start - now);
  return Math.floor(diffInMs / (1000 * 60 * 60 * 24 * 365));
};
---

<Container className="pt-2 pb-4 md:pt-6 md:pb-8">
  <div id="about" class="md:pt-16 lg:pt-24">
    <div class="md:flex md:mb-4">
      <div class="w-1/3 md:w-2/6 lg:w-1/6 mb-2">
        <Image
          class="shadow-lg rounded-lg max-w-full h-auto align-middle border-4 border-gray-200"
          src="/images/avatar.webp"
          alt="avatar"
          width={250}
          height={250}
        />
      </div>
      <div class="md:w-4/6 lg:w-5/6 md:mx-8 lg:mx-12">
        <h2
          class="text-xl md:text-3xl lg:text-5xl font-bold mb-2 inline-block bg-gradient-to-r from-purple-600 via-purple-500 to-purple-600 bg-clip-text text-transparent"
        >
          Who I am
        </h2>
        <p class="text-sm md:text-base lg:text-xl text-gray-300">
          Senior React/React Native developer with {getDiffOfYears()}
          years of experience building modern web and mobile applications.
        </p>
        <p class="text-sm md:text-base lg:text-xl text-gray-300 mt-2">
          I specialize in React, React Native, Next.js, TypeScript, and
          Tailwind, with experience across data-driven applications, fintech,
          and digital transformation — working in environments ranging from
          startups to large institutions.
        </p>
      </div>
    </div>

    <div>
      <p class="text-sm md:text-base lg:text-xl text-gray-300 mt-2">
        On the frontend, I work with
        <span class={highlightedStyle}> React</span>,
        <span class={highlightedStyle}> Next.js</span>,
        <span class={highlightedStyle}> TypeScript</span>, and
        <span class={highlightedStyle}> Tailwind</span>.
        For mobile, I use
        <span class={highlightedStyle}> React Native</span> with
        <span class={highlightedStyle}> Expo</span>.
      </p>

      <p class="text-sm md:text-base lg:text-xl text-gray-300 mt-2">
        On the backend, I rely on
        <span class={highlightedStyle}> Convex</span> for side projects,
        keeping things simple with a realtime, type-safe platform that
        handles the heavy lifting.
      </p>


    </div>
  </div>
</Container>
<Divider className="my-8 md:my-10 lg:my-12" />
