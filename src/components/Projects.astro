---
import Container from "./common/Container.astro";
import Divider from "./common/Divider.astro";

type Project = {
  title: string;
  description: string;
  url: string;
  callToAction: string;
};

const projects: Project[] = [
  {
    title: "UI Test Helper",
    description:
      "Chrome extension that generates Testing Library queries by inspecting UI elements, making it faster to write accessible and resilient tests.",
    url: "https://chromewebstore.google.com/detail/clldjgjeoglmkeoepnnfncfpiebjafgo",
    callToAction: "Add to Chrome",
  },
  {
    title: "IconCombo",
    description:
      "App icon generator for iOS and Android that makes it easy to create and preview icons for your mobile apps.",
    url: "https://www.iconcombo.com",
    callToAction: "Try it",
  },
  {
    title: "Birthday Tracker & Countdown",
    description:
      "iOS app that helps you never miss a birthday. Import contacts, get push notifications, and view countdowns with a clean, intuitive interface.",
    url: "https://apps.apple.com/lu/app/birthday-tracker-countdown/id6759844133",
    callToAction: "Download",
  },
];
---

<Container className="pt-2 pb-4 md:pt-6 md:pb-8">
  <h2
    class:list={[
      "text-xl md:text-3xl lg:text-5xl font-bold mb-2 inline-block",
      "bg-gradient-to-r from-purple-600 via-purple-500 to-purple-600 bg-clip-text text-transparent",
    ]}
  >
    Things I've Built
  </h2>
  <p class="text-sm md:text-base lg:text-xl text-gray-300 mb-4">
    Here are some of the things I've built. I'm always working on new projects,
    so check back often!
  </p>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {
      projects.map((project) => (
        <div class="border-4 border-gray-300 rounded-lg shadow-lg p-4">
          <h3 class="text-xl font-bold mb-2">
            <a
              class="text-base md:text-lg lg:text-2xl text-pink-600 hover:text-pink-500"
              href={project.url}
              target="_blank"
            >
              {project.title}
            </a>
          </h3>
          <p class="text-gray-300 text-xs sm:text-sm mb-4">
            {project.description}
          </p>
          <div>
            <a
              class="text-xs md:text-base text-pink-600 hover:text-pink-500"
              href={project.url}
              target="_blank"
            >
              {project.callToAction} &gt;
            </a>
          </div>
        </div>
      ))
    }
  </div>
  <a
    class="text-sm md:text-base lg:text-xl text-pink-600 mt-4 md:mt-6 inline-block underline"
    href="https://github.com/abdelhak-ajbouni?tab=repositories"
    target="_blank"
  >
    Check my Github
  </a>
</Container>
<Divider className="my-8 md:my-10 lg:my-12" />
